; Minimal tiny-model .COM startup.
; No libc, no heap, no argv. Calls main_, then DOS exit.
; Watcom default calling convention is __watcall: int return is in AX.
;
; Before calling main, shrink our memory block to TOOPACK_PARAGRAPHS so
; INT 21h AH=48h has free conventional memory to hand back. Without this,
; the .COM owns all memory and AH=48h returns "no free block".

TOOPACK_PARAGRAPHS  EQU  256     ; 16 KB: program + stack + slack

        .8086

DGROUP  group   _TEXT, CONST, CONST2, _DATA, _BSS

_TEXT   segment word public 'CODE'
        assume  cs:DGROUP, ds:DGROUP, ss:DGROUP, es:DGROUP

        org     100h            ; .COM load address

        public  _cstart_
        extrn   main_:near

_cstart_:
        mov     bx, TOOPACK_PARAGRAPHS
        mov     ah, 4Ah         ; resize our memory block
        int     21h
        ; (Ignore CF: even on failure we still try to run.)
        call    main_
        mov     ah, 4Ch         ; DOS exit, AL = main's return value
        int     21h

_TEXT   ends

CONST   segment word public 'DATA'
CONST   ends
CONST2  segment word public 'DATA'
CONST2  ends
_DATA   segment word public 'DATA'
_DATA   ends
_BSS    segment word public 'BSS'
_BSS    ends

        end     _cstart_
